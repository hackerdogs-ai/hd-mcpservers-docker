{
  "mcpServers": {
    "notion-mcp": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "MCP_TRANSPORT",
        "-e",
        "OPENAI_API_KEY",
        "-e",
        "NOTION_TOKEN",
        "hackerdogs/notion-mcp:latest"
      ],
      "env": {
        "MCP_TRANSPORT": "stdio",
        "OPENAI_API_KEY": "",
        "NOTION_TOKEN": ""
      }
    }
  }
}
