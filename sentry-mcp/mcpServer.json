{
  "mcpServers": {
    "sentry-mcp": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "MCP_TRANSPORT",
        "-e",
        "SENTRY_AUTH_TOKEN",
        "hackerdogs/sentry-mcp:latest"
      ],
      "env": {
        "MCP_TRANSPORT": "stdio",
        "SENTRY_AUTH_TOKEN": ""
      }
    }
  }
}
