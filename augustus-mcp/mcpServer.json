{
  "mcpServers": {
    "augustus-mcp": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e", "OPENAI_API_KEY",
        "-e", "ANTHROPIC_API_KEY",
        "hackerdogs/augustus-mcp:latest"
      ],
      "env": {
        "OPENAI_API_KEY": "<your-openai-api-key>",
        "ANTHROPIC_API_KEY": "<your-anthropic-api-key>"
      }
    }
  }
}
