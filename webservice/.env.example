# =============================================================================
# Tools catalog source (set one)
# =============================================================================
# S3 (requires AWS credentials):
# TOOLS_CATALOG_S3_URI=s3://your-bucket/catalog.json
#
# HTTPS:
# TOOLS_CATALOG_URL=https://example.com/tools-catalog.json
#
# Local testing (no Docker): run "python scripts/csv_to_catalog.py" then set
# file:// + absolute path to catalog.json (three slashes after file:)
# TOOLS_CATALOG_URL=file:///Users/you/repo/hd-mcpservers-docker/webservice/catalog.json

# =============================================================================
# Optional
# =============================================================================
TOOLS_CACHE_TTL_SECONDS=300
TOOL_RUN_TIMEOUT_SECONDS=120
LOG_LEVEL=INFO
# PORT=8000
