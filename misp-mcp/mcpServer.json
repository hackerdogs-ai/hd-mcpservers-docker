{
  "mcpServers": {
    "misp-mcp": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "MCP_TRANSPORT",
        "-e",
        "MISP_API_KEY",
        "-e",
        "MISP_URL",
        "hackerdogs/misp-mcp:latest"
      ],
      "env": {
        "MCP_TRANSPORT": "stdio",
        "MISP_API_KEY": "",
        "MISP_URL": ""
      }
    }
  }
}
