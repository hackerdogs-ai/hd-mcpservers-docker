{
  "mcpServers": {
    "onionsearch-mcp": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "MCP_TRANSPORT",
        "-e",
        "TOR_PROXY",
        "hackerdogs/onionsearch-mcp:latest"
      ],
      "env": {
        "MCP_TRANSPORT": "stdio",
        "TOR_PROXY": "127.0.0.1:9050"
      }
    }
  }
}
