{
  "mcpServers": {
    "victorialogs-mcp": {
      "command": "docker",
      "args": ["run", "-i", "--rm", "-e", "MCP_TRANSPORT", "-e", "MCP_PORT", "-e", "VICTORIALOGS_URL", "hackerdogs/victorialogs-mcp:latest"],
      "env": {
        "MCP_TRANSPORT": "stdio",
        "VICTORIALOGS_URL": "http://localhost:9428"
      }
    }
  }
}
