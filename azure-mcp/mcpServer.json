{
  "mcpServers": {
    "azure-mcp": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "MCP_TRANSPORT",
        "-e",
        "AZURE_CLIENT_ID",
        "-e",
        "AZURE_CLIENT_SECRET",
        "-e",
        "AZURE_TENANT_ID",
        "-e",
        "AZURE_SUBSCRIPTION_ID",
        "hackerdogs/azure-mcp:latest"
      ],
      "env": {
        "MCP_TRANSPORT": "stdio",
        "AZURE_CLIENT_ID": "",
        "AZURE_CLIENT_SECRET": "",
        "AZURE_TENANT_ID": "",
        "AZURE_SUBSCRIPTION_ID": ""
      }
    }
  }
}
