{
  "mcpServers": {
    "cloudflare-mcp": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "MCP_TRANSPORT",
        "-e",
        "CLOUDFLARE_API_TOKEN",
        "-e",
        "CLOUDFLARE_ACCOUNT_ID",
        "hackerdogs/cloudflare-mcp:latest"
      ],
      "env": {
        "MCP_TRANSPORT": "stdio",
        "CLOUDFLARE_API_TOKEN": "",
        "CLOUDFLARE_ACCOUNT_ID": ""
      }
    }
  }
}
