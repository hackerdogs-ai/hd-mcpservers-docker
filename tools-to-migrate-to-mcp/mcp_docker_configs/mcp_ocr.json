{
  "name": "ocr",
  "package_name": "mcp-ocr",
  "base_image": "python:3.11-slim",
  "additional_packages": [
    "tesseract-ocr",
    "tesseract-ocr-eng",
    "libgl1",
    "libglib2.0-0",
    "libsm6",
    "libxext6",
    "libxrender-dev",
    "libgomp1"
  ],
  "entrypoint": "python -m mcp_ocr",
  "description": "MCP OCR Server - Extract text from images using Tesseract OCR",
  "env": {
    "PYTHONUNBUFFERED": "1"
  },
  "capabilities": [
    "ocr",
    "image-processing",
    "text-extraction"
  ]
}

