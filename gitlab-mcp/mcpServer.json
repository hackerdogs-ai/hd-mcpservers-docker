{
  "mcpServers": {
    "gitlab-mcp": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "MCP_TRANSPORT",
        "-e",
        "GITLAB_PERSONAL_ACCESS_TOKEN",
        "hackerdogs/gitlab-mcp:latest"
      ],
      "env": {
        "MCP_TRANSPORT": "stdio",
        "GITLAB_PERSONAL_ACCESS_TOKEN": ""
      }
    }
  }
}
