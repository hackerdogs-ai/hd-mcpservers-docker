{
  "mcpServers": {
    "brightdata-mcp-server-mcp": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "MCP_TRANSPORT",
        "-e",
        "API_TOKEN",
        "hackerdogs/brightdata-mcp-server-mcp:latest"
      ],
      "env": {
        "MCP_TRANSPORT": "stdio",
        "API_TOKEN": ""
      }
    }
  }
}
